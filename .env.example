APP_NAME=okx-ai-futures-live-autonomy
APP_ENV=production

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_BASE_URL=https://www.okx.com
OKX_IS_DEMO=false

OPENAI_API_KEY=
ENABLE_GPT_REFLECTION=true
ENABLE_DAILY_GPT_REVIEW=true
GPT_MODEL=gpt-5.4
GPT_TIMEOUT_SEC=30
GPT_REASONING_EFFORT=medium
GPT_DELIBERATION_ROUNDS=3
GPT_REVIEW_TIMEZONE=Asia/Taipei
DAILY_REVIEW_MIN_TRADES=6

INSTRUMENT_TYPE=SWAP
PRIMARY_TIMEFRAME=15m
SCAN_TOP_N=50
SCAN_SYMBOL_INTERVAL_SEC=0.005
CANDLE_LIMIT=240

RUNTIME_LOOP_ENABLED=true
RUNTIME_LOOP_SLEEP_SEC=50

ENABLE_LIVE_EXECUTION=true
ENABLE_POSITION_SYNC=true
ENABLE_PROTECTIVE_ORDERS=true
ENABLE_POSITION_MANAGER=true
ENABLE_POSITION_LIFECYCLE=true

KILL_SWITCH=false
REQUIRE_CREDENTIALS_CHECK=true
REQUIRE_ACCOUNT_CONFIG_CHECK=true
REQUIRE_MAX_AVAIL_CHECK=true

MAX_LIVE_ENTRIES_PER_CYCLE=4
MAX_OPEN_POSITIONS=10
MAX_TOTAL_RISK_PCT=0.18
MAX_CONSECUTIVE_LOSSES_BEFORE_PAUSE=10

MIN_TRADE_CONFIDENCE=0.53
MIN_WATCH_CONFIDENCE=0.42
MAX_ADD_POSITION_MULTIPLIER=1.8
HARD_STOP_LOSS_PCT=0.012
MIN_LOCK_PROFIT_PCT=0.002
BREAK_EVEN_TRIGGER_RR=1.0
TRAILING_ACTIVATION_RR=1.4
TRAILING_BUFFER_ATR=0.8
INITIAL_STOP_LOSS_ATR=1.8
INITIAL_TAKE_PROFIT_ATR=3.0

DEFAULT_LEVERAGE_MIN=3
DEFAULT_LEVERAGE_MAX=20
DEFAULT_MARGIN_PCT_MIN=0.01
DEFAULT_MARGIN_PCT_MAX=0.08

ADAPTIVE_MIN_TRADE_CONFIDENCE_FLOOR=0.45
ADAPTIVE_MIN_TRADE_CONFIDENCE_CEILING=0.72
ADAPTIVE_SIZE_FLOOR=0.35
ADAPTIVE_SIZE_CEILING=2.4
ADAPTIVE_LEVERAGE_FLOOR=2
ADAPTIVE_LEVERAGE_CEILING=25

TD_MODE=cross
FORCE_POS_SIDE_IN_NET_MODE=false

AI_CONTROLS_ENTRY=true
AI_CONTROLS_SIZING=true
AI_CONTROLS_LEVERAGE=true
AI_CONTROLS_PROTECTION=true
AI_CONTROLS_EXIT=true
AI_CONTROLS_PARAMETER_ADAPTATION=true
AUTONOMY_REQUIRED_RATIO=1.0

DATA_DIR=data
STATE_DIR=state
UI_HOST=0.0.0.0
UI_PORT=8090

LIFECYCLE_MIN_POSITION_SIZE=1.0
LIFECYCLE_ADD_THRESHOLD=0.78
LIFECYCLE_REDUCE_THRESHOLD=0.32
LIFECYCLE_PARTIAL_TAKE_PROFIT_RR=1.6
LIFECYCLE_REDUCE_FRACTION=0.25
LIFECYCLE_ADD_FRACTION=0.35
LIFECYCLE_MAX_SCALE_INS_PER_POSITION=2
LIFECYCLE_MAX_PARTIAL_EXITS_PER_POSITION=2
LIFECYCLE_TP1_FRACTION=0.25
LIFECYCLE_TP2_FRACTION=0.35
LIFECYCLE_BREAK_EVEN_LOCK_RATIO=0.15
LIFECYCLE_TRAILING_STEP_RR=0.45
LIFECYCLE_PROTECTION_REFRESH_COOLDOWN_SEC=120
